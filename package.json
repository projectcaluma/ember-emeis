{
  "name": "ember-emeis",
  "version": "8.1.0",
  "description": "The frontend for the emeis user management service",
  "keywords": [
    "ember-addon",
    "ember-engine",
    "emeis",
    "caluma"
  ],
  "repository": "github:projectcaluma/ember-emeis",
  "license": "LGPL-3.0-or-later",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.scss\"",
    "lint:css:fix": "concurrently \"pnpm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:pkg": "npmPkgJsonLint .",
    "start": "ember serve",
    "start-proxy": "ember server --proxy http://localhost:8000",
    "test": "concurrently \"pnpm:lint\" \"pnpm:test:*\" --names \"lint,test:\" --prefixColors auto",
    "test:ember": "ember test",
    "test:ember-compatibility": "ember try:each",
    "prepare": "husky install"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.hbs": "ember-template-lint --fix",
    "package.json": "npmPkgJsonLint .",
    "*.{scss,graphql,json,md,yml}": "prettier --write"
  },
  "dependencies": {
    "@embroider/macros": "^1.19.1",
    "@glimmer/component": "^2.0.0",
    "@glimmer/tracking": "^1.1.2",
    "ember-auto-import": "^2.11.1",
    "ember-basic-dropdown": "^8.8.0",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-composable-helpers": "^5.0.0",
    "ember-concurrency": "^4.0.6",
    "ember-intl": "^7.4.1",
    "ember-load-initializers": "^2.1.2 || ^3.0.1",
    "ember-modifier": "^4.2.2",
    "ember-power-select": "^8.11.0",
    "ember-resolver": "^13.1.1",
    "ember-resources": "^7.0.7",
    "ember-set-helper": "^3.1.0",
    "ember-template-imports": "^4.3.0",
    "ember-test-selectors": "^7.1.0",
    "ember-truth-helpers": "^5.0.0",
    "ember-uikit": "^9.1.4",
    "file-saver": "^2.0.5",
    "reactiveweb": "^1.9.0",
    "tracked-toolbox": "^2.0.0"
  },
  "devDependencies": {
    "@adfinis/eslint-config": "3.0.2",
    "@adfinis/semantic-release-config": "4.0.0",
    "@babel/core": "7.28.5",
    "@babel/eslint-parser": "7.28.5",
    "@babel/plugin-proposal-decorators": "7.28.0",
    "@commitlint/cli": "17.6.6",
    "@commitlint/config-conventional": "17.6.6",
    "@ember-data/adapter": "4.12.8",
    "@ember-data/debug": "4.12.8",
    "@ember-data/graph": "4.12.8",
    "@ember-data/json-api": "4.12.8",
    "@ember-data/legacy-compat": "4.12.8",
    "@ember-data/model": "4.12.8",
    "@ember-data/serializer": "4.12.8",
    "@ember-data/store": "4.12.8",
    "@ember/optional-features": "2.2.0",
    "@ember/string": "3.1.1",
    "@ember/test-helpers": "5.4.0",
    "@embroider/test-setup": "4.0.0",
    "@eslint/js": "9.37.0",
    "@faker-js/faker": "6.2.0",
    "@glint/template": "1.7.2",
    "broccoli-asset-rev": "3.0.0",
    "concurrently": "9.2.1",
    "ember-cli": "6.8.0",
    "ember-cli-clean-css": "3.0.0",
    "ember-cli-dependency-checker": "3.3.3",
    "ember-cli-deprecation-workflow": "3.4.0",
    "ember-cli-inject-live-reload": "2.1.0",
    "ember-cli-mirage": "3.0.4",
    "ember-cli-sass": "11.0.1",
    "ember-cli-terser": "4.0.2",
    "ember-data": "4.12.8",
    "ember-engines": "0.12.0",
    "ember-inflector": "4.0.2",
    "ember-maybe-import-regenerator": "1.0.0",
    "ember-qunit": "9.0.4",
    "ember-source": "6.4.0",
    "ember-source-channel-url": "3.0.0",
    "ember-template-lint": "6.1.0",
    "ember-template-lint-plugin-prettier": "4.2.0",
    "ember-try": "4.0.0",
    "eslint": "9.37.0",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-ember": "12.7.4",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-n": "17.23.1",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-qunit": "8.2.5",
    "globals": "15.15.0",
    "husky": "8.0.3",
    "lint-staged": "15.0.2",
    "loader.js": "4.7.0",
    "miragejs": "0.1.48",
    "npm-package-json-lint": "6.4.0",
    "npm-run-all": "4.1.5",
    "postcss-scss": "4.0.9",
    "prettier": "3.6.2",
    "prettier-plugin-ember-template-tag": "2.1.0",
    "qunit": "2.24.2",
    "qunit-dom": "3.5.0",
    "sass": "1.63.6",
    "stylelint": "16.25.0",
    "stylelint-config-standard": "36.0.1",
    "stylelint-prettier": "5.0.3",
    "webpack": "5.102.1"
  },
  "peerDependencies": {
    "@ember-data/legacy-compat": "~4.12.8 || >= 5.0.0",
    "@ember-data/model": "~4.12.8 || >= 5.0.0",
    "@ember-data/serializer": "~4.12.8 || >= 5.0.0",
    "@ember-data/store": "~4.12.8 || >= 5.0.0",
    "ember-data": "~4.12.8 || >= 5.0.0",
    "ember-engines": "^0.12.0",
    "ember-source": ">= 4.0.0"
  },
  "pnpm": {
    "//": [
      "ember/test-waiters: enforce at least 3.1.0 with patched waitForPromise"
    ],
    "overrides": {
      "@ember/test-waiters": "3.1.0"
    }
  },
  "engines": {
    "node": ">= 20.11"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "configPath": "tests/dummy/config"
  },
  "release": {
    "extends": "@adfinis/semantic-release-config"
  },
  "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40"
}
