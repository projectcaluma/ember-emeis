{
  "name": "ember-emeis",
  "version": "8.1.0",
  "description": "The frontend for the emeis user management service",
  "keywords": [
    "ember-addon",
    "ember-engine",
    "emeis",
    "caluma"
  ],
  "repository": "github:projectcaluma/ember-emeis",
  "license": "LGPL-3.0-or-later",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\"",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:pkg": "npmPkgJsonLint .",
    "start": "ember serve",
    "start-proxy": "ember server --proxy http://localhost:8000",
    "test": "concurrently \"npm:lint\" \"yarn:test:*\" --names \"lint,test:\"",
    "test:ember": "ember test",
    "test:ember-compatibility": "ember try:each",
    "prepare": "husky install"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.hbs": "ember-template-lint --fix",
    "package.json": "npmPkgJsonLint .",
    "*.{scss,graphql,json,md,yml}": "prettier --write"
  },
  "dependencies": {
    "@babel/core": "^7.25.2",
    "@ember/legacy-built-in-components": "^0.4.2",
    "@ember/render-modifiers": "^2.0.5",
    "@embroider/macros": "^1.16.9",
    "@glimmer/component": "^1.1.2",
    "@glimmer/tracking": "^1.1.2",
    "ember-auto-import": "^2.11.1",
    "ember-basic-dropdown": "^8.8.0",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-composable-helpers": "^5.0.0",
    "ember-concurrency": "^4.0.6",
    "ember-inflector": "^4.0.2",
    "ember-intl": "^7.4.1",
    "ember-modifier": "^4.2.2",
    "ember-power-select": "^8.11.0",
    "ember-resources": "^7.0.7",
    "ember-set-helper": "^3.1.0",
    "ember-test-selectors": "^7.1.0",
    "ember-truth-helpers": "^4.0.3",
    "ember-uikit": "^9.1.4",
    "file-saver": "^2.0.5",
    "reactiveweb": "^1.9.0",
    "tracked-toolbox": "^2.0.0"
  },
  "devDependencies": {
    "@adfinis/eslint-config": "2.1.1",
    "@adfinis/semantic-release-config": "4.0.0",
    "@babel/core": "7.28.4",
    "@babel/eslint-parser": "7.28.4",
    "@babel/plugin-proposal-decorators": "7.28.0",
    "@commitlint/cli": "17.6.6",
    "@commitlint/config-conventional": "17.6.6",
    "@ember-data/model": "4.12.8",
    "@ember-data/serializer": "4.12.8",
    "@ember/optional-features": "2.1.0",
    "@ember/test-helpers": "5.3.0",
    "@embroider/compat": "3.7.0",
    "@embroider/core": "3.4.19",
    "@embroider/test-setup": "4.0.0",
    "@embroider/webpack": "4.0.8",
    "@faker-js/faker": "6.2.0",
    "broccoli-asset-rev": "3.0.0",
    "concurrently": "8.2.2",
    "ember-cli": "5.12.0",
    "ember-cli-clean-css": "3.0.0",
    "ember-cli-dependency-checker": "3.3.2",
    "ember-cli-inject-live-reload": "2.1.0",
    "ember-cli-mirage": "3.0.0-alpha.3",
    "ember-cli-sass": "11.0.1",
    "ember-cli-sri": "2.1.1",
    "ember-cli-uglify": "3.0.0",
    "ember-data": "4.12.8",
    "ember-engines": "0.9.0",
    "ember-load-initializers": "2.1.2",
    "ember-maybe-import-regenerator": "1.0.0",
    "ember-qunit": "9.0.4",
    "ember-resolver": "13.1.1",
    "ember-source": "5.12.0",
    "ember-source-channel-url": "3.0.0",
    "ember-template-lint": "6.0.0",
    "ember-template-lint-plugin-prettier": "4.2.0",
    "ember-try": "3.0.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-ember": "12.2.1",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-n": "16.6.2",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-qunit": "8.1.2",
    "husky": "8.0.3",
    "lint-staged": "15.0.2",
    "loader.js": "4.7.0",
    "miragejs": "0.1.47",
    "npm-package-json-lint": "6.4.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.3.3",
    "qunit": "2.22.0",
    "qunit-dom": "3.2.1",
    "sass": "1.63.6",
    "stylelint": "15.11.0",
    "stylelint-config-standard": "34.0.0",
    "stylelint-prettier": "4.1.0",
    "webpack": "5.97.1"
  },
  "peerDependencies": {
    "@ember-data/model": "~4.12.8 || >= 5.0.0",
    "@ember-data/serializer": "~4.12.8 || >= 5.0.0",
    "ember-source": ">= 4.0.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "configPath": "tests/dummy/config"
  },
  "release": {
    "extends": "@adfinis/semantic-release-config"
  },
  "//": [
    "TODO(miragejs): conflicts with ember-cli-mirage in floating dependencies test"
  ],
  "resolutions": {
    "miragejs": "0.1.47"
  },
  "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40"
}
