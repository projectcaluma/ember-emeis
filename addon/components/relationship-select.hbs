<input
  class="hidden-input"
  value={{or (or @selected.id @selected.length) ""}}
  ...attributes
  {{setup-element (perform this.fetchModels)}}
/>
<this.selectComponent
  @searchEnabled={{this.searchEnabled}}
  @search={{perform this.fetchModels}}
  @options={{this.models}}
  @selected={{@selected}}
  @placeholder={{if
    this.fetchModels.isRunning
    (t "emeis.loading")
    @placeholder
  }}
  @noMatchesMessage={{t "emeis.empty"}}
  @renderInPlace={{true}}
  @allowClear={{true}}
  @onChange={{@onChange}}
  {{track-update (perform this.fetchModels) @model}}
  as |model|
>
  {{yield model}}
</this.selectComponent>